# ==========================================================================
# FacturZen — environment variables
# Copy to `.env` and fill in. Required vars must be set or the app won't boot
# (a clear error tells you which one is missing). Optional vars unlock features;
# when absent, the app degrades cleanly. Full walkthrough: DEPLOY.md
# ==========================================================================

# --- REQUIRED -------------------------------------------------------------

# PostgreSQL connection string (dev + prod both use Postgres — no SQLite).
#   • Local via Docker (see docker-compose.yml): start with `docker compose up -d`
#     then use the URL below.
#   • Or a hosted Postgres (Neon / Prisma Postgres / Supabase): paste its URL.
DATABASE_URL="postgresql://facturzen:facturzen@localhost:5432/facturzen?schema=public"

# Auth.js session encryption secret. Generate: `npx auth secret` (or `openssl rand -base64 33`)
AUTH_SECRET=""

# Public origin of the app — used to build absolute links (emails, PDF, OG).
# Dev: http://localhost:3000   Prod: https://<votre-domaine-vercel>
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Shared secret protecting the /api/cron/* routes. Generate: `openssl rand -hex 32`
# On Vercel this is also what Vercel Cron sends as `Authorization: Bearer <...>`.
CRON_SECRET=""

# --- OPTIONAL (feature flags — absence degrades gracefully) ---------------

# Google OAuth — optionnel AU DÉPLOIEMENT, requis pour ACTIVER la connexion.
# Sans les DEUX clés : landing + démo tournent, /connexion affiche "bientôt",
# et la connexion s'active dès qu'elles sont ajoutées (redéployer suffit).
# https://console.cloud.google.com/apis/credentials — redirect URIs (DEPLOY.md §4) :
#   http://localhost:3000/api/auth/callback/google
#   https://<votre-domaine-vercel>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend — transactional emails (sending docs, reminders, receipts). Without it,
# emails are logged ([email:simulated]) and Réglages shows "non configuré".
# https://resend.com/api-keys
RESEND_API_KEY=""
# Sender identity. Defaults to Resend's test sender (onboarding@resend.dev), which
# in test mode only delivers to your own account's verified addresses. In prod,
# use a verified domain sender, e.g. "FacturZen <notifications@votre-domaine.ch>".
EMAIL_FROM=""

# Stripe — subscriptions (Réglages → Abonnement) AND online invoice payments via
# Stripe Connect (Réglages → Paiements + page publique /f). Without STRIPE_SECRET_KEY,
# both degrade cleanly (bank transfer still works; no dead buttons).
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Webhook signing secret. Local: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and copy the whsec_... it prints.
STRIPE_WEBHOOK_SECRET=""
# Publishable key (client). Optional — Checkout is redirect-based, so not strictly required.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Subscription Price IDs (create recurring 24 / 49 CHF prices in Stripe → Products).
STRIPE_PRICE_INDEP=""
STRIPE_PRICE_STUDIO=""

# Vercel Blob — file uploads (company logo). Without it in prod, logo upload
# shows "Stockage de fichiers non configuré". In dev, files go to public/uploads.
# Create a Blob store in Vercel → Storage, then pull the token.
BLOB_READ_WRITE_TOKEN=""

# Anthropic — AI-assisted quote drafting. Without it, the AI devis feature is hidden.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
